# Copy to `.env` and fill in real values. Never commit `.env`.

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@localhost/meal_planner

# Optional — Meal Ideas (OpenAI)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Security (optional) ---
# development | production — production disables /docs and /redoc
# ENVIRONMENT=development

# Comma-separated browser origins allowed for CORS (your Vite dev server)
# ALLOWED_ORIGINS=http://localhost:8081

# Comma-separated Host header values the API will accept (TrustedHostMiddleware)
# TRUSTED_HOSTS=localhost,127.0.0.1

# Per-IP limits for POST /suggestions/dishes (expensive LLM calls)
# SUGGESTIONS_RATE_LIMIT_MAX=30
# SUGGESTIONS_RATE_LIMIT_WINDOW_SECONDS=60
